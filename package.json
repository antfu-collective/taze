{
  "name": "taze",
  "type": "module",
  "version": "19.11.0",
  "packageManager": "pnpm@10.33.0",
  "description": "A modern CLI tool that keeps your dependencies fresh in any repo and monorepo",
  "license": "MIT",
  "funding": "https://github.com/sponsors/antfu",
  "homepage": "https://github.com/antfu-collective/taze#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/antfu-collective/taze.git"
  },
  "bugs": {
    "url": "https://github.com/antfu-collective/taze/issues"
  },
  "exports": {
    ".": "./dist/index.mjs",
    "./cli": "./dist/cli.mjs",
    "./package.json": "./package.json"
  },
  "types": "dist/index.d.mts",
  "bin": {
    "taze": "bin/taze.mjs"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "lint": "eslint",
    "dev": "DEBUG=taze:* tsx ./src/cli.ts",
    "start": "tsx ./src/cli.ts",
    "build": "tsdown",
    "typecheck": "tsc",
    "prepublishOnly": "nr build",
    "release": "bumpp",
    "test": "tsdown && vitest"
  },
  "dependencies": {
    "@antfu/ni": "catalog:prod",
    "@henrygd/queue": "catalog:prod",
    "cac": "catalog:prod",
    "find-up-simple": "catalog:prod",
    "ofetch": "catalog:prod",
    "package-manager-detector": "catalog:prod",
    "pathe": "catalog:prod",
    "pnpm-workspace-yaml": "catalog:prod",
    "restore-cursor": "catalog:prod",
    "tinyexec": "catalog:prod",
    "tinyglobby": "catalog:prod",
    "unconfig": "catalog:prod",
    "yaml": "catalog:prod"
  },
  "devDependencies": {
    "@antfu/eslint-config": "catalog:dev",
    "@antfu/utils": "catalog:inlined",
    "@posva/prompts": "catalog:inlined",
    "@types/cli-progress": "catalog:types",
    "@types/debug": "catalog:types",
    "@types/node": "catalog:types",
    "ansis": "catalog:inlined",
    "bumpp": "catalog:dev",
    "cli-progress": "catalog:inlined",
    "debug": "catalog:inlined",
    "deepmerge": "catalog:inlined",
    "detect-indent": "catalog:inlined",
    "eslint": "catalog:dev",
    "get-npm-meta": "catalog:inlined",
    "semver-es": "catalog:inlined",
    "taze": "workspace:*",
    "tsdown": "catalog:dev",
    "tsx": "catalog:dev",
    "typescript": "catalog:dev",
    "vitest": "catalog:dev"
  },
  "inlinedDependencies": {
    "@antfu/utils": "9.3.0",
    "@posva/prompts": "2.4.4",
    "ansi-regex": "5.0.1",
    "ansis": "4.2.0",
    "cli-progress": "3.12.0",
    "debug": "4.4.3",
    "deepmerge": "4.3.1",
    "detect-indent": "7.0.2",
    "emoji-regex": "8.0.0",
    "fast-npm-meta": "1.4.2",
    "get-npm-meta": "0.1.2",
    "is-fullwidth-code-point": "3.0.0",
    "kleur": "4.1.5",
    "ms": "2.1.3",
    "semver-es": "0.1.1",
    "sisteransi": "1.0.5",
    "string-width": "4.2.3",
    "strip-ansi": "6.0.1"
  }
}
